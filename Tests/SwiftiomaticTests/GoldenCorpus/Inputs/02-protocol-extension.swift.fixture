import Foundation

public protocol Cache {
associatedtype Key: Hashable
associatedtype Value
func get(_ key: Key) -> Value?
func set(_ key: Key, _ value: Value)
}

extension Cache where Value: Equatable {
public func contains(value: Value) -> Bool {
return false
}
}

public struct LRU<K: Hashable, V>: Cache {
private var entries: [K: V] = [:]
public init() {}
public func get(_ key: K) -> V? { entries[key] }
public func set(_ key: K, _ value: V) {}
}
