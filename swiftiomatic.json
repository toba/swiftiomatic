{
  "$schema" : "https://raw.githubusercontent.com/toba/swiftiomatic/refs/heads/main/schema.json",
  "ambiguousTrailingClosureOverload" : { "lint" : "warn" },
  "blankLines" : {
    "afterGuardStatements" : { "lint" : "no", "rewrite" : false },
    "afterImports" : { "lint" : "warn", "rewrite" : true },
    "afterSwitchCase" : { "lint" : "no", "rewrite" : false },
    "beforeAndAfterMark" : { "lint" : "no", "rewrite" : false },
    "betweenChainedFunctions" : { "lint" : "no", "rewrite" : false },
    "betweenImports" : { "lint" : "no", "rewrite" : false },
    "betweenScopes" : { "lint" : "no", "rewrite" : false },
    "consistentSwitchCaseSpacing" : { "lint" : "no", "rewrite" : false },
    "maximumBlankLines" : 1
  },
  "capitalization" : {
    "camelCaseIdentifiers" : { "lint" : "warn" },
    "capitalizeAcronyms" : {
      "lint" : "no",
      "rewrite" : false,
      "words" : [
        "ID",
        "URL",
        "UUID",
        "HTTP",
        "HTTPS",
        "JSON",
        "XML",
        "HTML",
        "API",
        "TCP",
        "UDP",
        "DNS",
        "SSH",
        "FTP",
        "SQL",
        "CSS",
        "RGB",
        "RGBA",
        "PDF",
        "GIF",
        "PNG",
        "JPEG"
      ]
    },
    "capitalizeTypeNames" : { "lint" : "warn" }
  },
  "collapseEmptyBraces" : { "lint" : "warn", "rewrite" : true },
  "comments" : {
    "commentsPrecedeModifiers" : { "lint" : "warn", "rewrite" : true },
    "convertRegularCommentToDocC" : { "lint" : "no", "rewrite" : false },
    "disallowBlockComments" : { "lint" : "warn" },
    "documentParameters" : { "lint" : "no" },
    "documentPublicDeclarations" : { "lint" : "no" },
    "formatCommentTypePrefix" : { "lint" : "warn", "rewrite" : true },
    "requireCommentSummary" : { "lint" : "no" },
    "tripleSlashDocComments" : { "lint" : "warn", "rewrite" : true }
  },
  "emptyExtensions" : { "lint" : "warn", "rewrite" : true },
  "explicitNilCheck" : { "lint" : "warn", "rewrite" : true },
  "fileHeader" : { "lint" : "no", "rewrite" : false },
  "fileScopedDeclarationPrivacy" : { "accessLevel" : "private", "lint" : "warn", "rewrite" : true },
  "forcing" : {
    "noForceTry" : { "lint" : "no", "rewrite" : false },
    "noForceUnwrap" : { "lint" : "no", "rewrite" : false }
  },
  "groupNumericLiterals" : { "lint" : "warn", "rewrite" : true },
  "hoist" : {
    "awaitWithinExpression" : { "lint" : "warn", "rewrite" : true },
    "indirectEnum" : { "lint" : "warn", "rewrite" : true },
    "tryWithinExpression" : { "lint" : "warn", "rewrite" : true }
  },
  "identifiersMayOnlyUseASCII" : { "lint" : "warn" },
  "indentation" : {
    "blankLines" : false,
    "conditionalCompilationBlocks" : false,
    "switchCaseIndentation" : { "lint" : "no", "rewrite" : false, "style" : "flush" },
    "unit" : { "spaces" : 4 }
  },
  "initCoderUnavailable" : { "lint" : "no", "rewrite" : false },
  "leadingDotOperators" : { "lint" : "warn", "rewrite" : true },
  "lineBreaks" : {
    "aroundMultilineExpressionChainComponents" : false,
    "beforeControlFlowKeywords" : false,
    "beforeEachArgument" : false,
    "beforeEachGenericRequirement" : false,
    "beforeGuardConditions" : true,
    "betweenDeclarationAttributes" : false,
    "ensureLineBreakAtEOF" : { "lint" : "no", "rewrite" : false },
    "modifiersOnSameLine" : { "lint" : "warn", "rewrite" : true }
  },
  "lineLength" : 100,
  "modifierOrder" : { "lint" : "warn", "rewrite" : true },
  "multiElementCollectionTrailingCommas" : true,
  "multilineTrailingCommaBehavior" : "keptAsWritten",
  "noAssignmentInExpressions" : {
    "allowedFunctions" : [
      "XCTAssertNoThrow"
    ],
    "lint" : "warn",
    "rewrite" : true
  },
  "noBacktickedSelf" : { "lint" : "warn", "rewrite" : true },
  "noEmptyLinesOpeningClosingBraces" : { "lint" : "no", "rewrite" : false },
  "noExplicitOwnership" : { "lint" : "no", "rewrite" : false },
  "noExtensionAccessLevel" : { "lint" : "warn", "placement" : "onDeclarations", "rewrite" : true },
  "noFallthroughOnlyCases" : { "lint" : "warn", "rewrite" : true },
  "noGuardInTests" : { "lint" : "no", "rewrite" : false },
  "noImplicitlyUnwrappedOptionals" : { "lint" : "no" },
  "noLabelsInCasePatterns" : { "lint" : "warn", "rewrite" : true },
  "noLeadingUnderscores" : { "lint" : "no" },
  "noParensAroundConditions" : { "lint" : "warn", "rewrite" : true },
  "noPlaygroundLiterals" : { "lint" : "warn" },
  "noRetroactiveConformances" : { "lint" : "warn" },
  "noSemicolons" : { "lint" : "warn", "rewrite" : true },
  "noTrailingClosureParens" : { "lint" : "warn", "rewrite" : true },
  "noTypeRepetitionInStaticProperties" : { "lint" : "warn" },
  "noVoidReturnOnFunctionSignature" : { "lint" : "warn", "rewrite" : true },
  "noYodaConditions" : { "lint" : "warn", "rewrite" : true },
  "oneDeclarationPerLine" : { "lint" : "warn", "rewrite" : true },
  "onlyOneTrailingClosureArgument" : { "lint" : "warn" },
  "opaqueGenericParameters" : { "lint" : "no", "rewrite" : false },
  "patternLetPlacement" : { "lint" : "warn", "placement" : "eachBinding", "rewrite" : true },
  "preferAngleBracketExtensions" : { "lint" : "warn", "rewrite" : true },
  "preferAnyObject" : { "lint" : "warn", "rewrite" : true },
  "preferAssertionFailure" : { "lint" : "warn", "rewrite" : true },
  "preferCommaConditions" : { "lint" : "warn", "rewrite" : true },
  "preferConditionalExpression" : { "lint" : "no", "rewrite" : false },
  "preferCountWhere" : { "lint" : "warn", "rewrite" : true },
  "preferEarlyExits" : { "lint" : "no", "rewrite" : false },
  "preferEnvironmentEntry" : { "lint" : "no", "rewrite" : false },
  "preferExplicitFalse" : { "lint" : "no", "rewrite" : false },
  "preferFileID" : { "lint" : "no", "rewrite" : false },
  "preferFinalClasses" : { "lint" : "no", "rewrite" : false },
  "preferIsEmpty" : { "lint" : "no", "rewrite" : false },
  "preferKeyPath" : { "lint" : "no", "rewrite" : false },
  "preferMainAttribute" : { "lint" : "warn", "rewrite" : true },
  "preferShorthandTypeNames" : { "lint" : "warn", "rewrite" : true },
  "preferSingleLinePropertyGetter" : { "lint" : "warn", "rewrite" : true },
  "preferSwiftTesting" : { "lint" : "no", "rewrite" : false },
  "preferSynthesizedInitializer" : { "lint" : "warn" },
  "preferTrailingClosures" : { "lint" : "warn", "rewrite" : true },
  "preferVoidReturn" : { "lint" : "warn", "rewrite" : true },
  "preferWhereClausesInForLoops" : { "lint" : "no", "rewrite" : false },
  "prioritizeKeepingFunctionOutputTogether" : false,
  "privateStateVariables" : { "lint" : "no", "rewrite" : false },
  "redundancies" : {
    "redundantAccessControl" : { "lint" : "no", "rewrite" : false },
    "redundantAsync" : { "lint" : "no", "rewrite" : false },
    "redundantBackticks" : { "lint" : "warn", "rewrite" : true },
    "redundantBreak" : { "lint" : "warn", "rewrite" : true },
    "redundantClosure" : { "lint" : "warn", "rewrite" : true },
    "redundantEquatable" : { "lint" : "no", "rewrite" : false },
    "redundantInit" : { "lint" : "warn", "rewrite" : true },
    "redundantLet" : { "lint" : "warn", "rewrite" : true },
    "redundantLetError" : { "lint" : "warn", "rewrite" : true },
    "redundantNilInit" : { "lint" : "warn", "rewrite" : true },
    "redundantObjc" : { "lint" : "warn", "rewrite" : true },
    "redundantOptionalBinding" : { "lint" : "warn", "rewrite" : true },
    "redundantPattern" : { "lint" : "warn", "rewrite" : true },
    "redundantProperty" : { "lint" : "warn", "rewrite" : true },
    "redundantRawValues" : { "lint" : "warn", "rewrite" : true },
    "redundantReturn" : { "lint" : "no", "rewrite" : false },
    "redundantSelf" : { "lint" : "warn", "rewrite" : true },
    "redundantSendable" : { "lint" : "no", "rewrite" : false },
    "redundantStaticSelf" : { "lint" : "no", "rewrite" : false },
    "redundantSwiftTestingSuite" : { "lint" : "no", "rewrite" : false },
    "redundantThrows" : { "lint" : "no", "rewrite" : false },
    "redundantType" : { "lint" : "warn", "rewrite" : true },
    "redundantTypedThrows" : { "lint" : "warn", "rewrite" : true },
    "redundantViewBuilder" : { "lint" : "no", "rewrite" : false }
  },
  "reflowMultilineStringLiterals" : "never",
  "replaceForEachWithForLoop" : { "lint" : "warn" },
  "respectsExistingLineBreaks" : true,
  "simplifyGenericConstraints" : { "lint" : "warn", "rewrite" : true },
  "sort" : {
    "sortDeclarations" : { "lint" : "warn", "rewrite" : true },
    "sortImports" : {
      "includeConditionalImports" : false,
      "lint" : "warn",
      "rewrite" : true,
      "shouldGroupImports" : true
    },
    "sortSwitchCases" : { "lint" : "no", "rewrite" : false },
    "sortTypeAliases" : { "lint" : "warn", "rewrite" : true }
  },
  "spacesAroundRangeFormationOperators" : false,
  "spacesBeforeEndOfLineComments" : 2,
  "staticStructShouldBeEnum" : { "lint" : "warn", "rewrite" : true },
  "strongOutlets" : { "lint" : "warn", "rewrite" : true },
  "swiftTestingTestCaseNames" : { "lint" : "no", "rewrite" : false },
  "tabWidth" : 8,
  "testSuiteAccessControl" : { "lint" : "no", "rewrite" : false },
  "unusedArguments" : { "lint" : "warn", "rewrite" : true },
  "uRLMacro" : { "lint" : "no", "rewrite" : false },
  "useShortArrayLiteral" : { "lint" : "no", "rewrite" : false },
  "validateTestCases" : { "lint" : "no", "rewrite" : false },
  "version" : 6,
  "wrap" : {
    "singleLineComments" : { "lint" : "no", "rewrite" : false },
    "wrapCompoundCaseStatements" : { "lint" : "no", "rewrite" : false },
    "wrapConditionalAssignment" : { "lint" : "no", "rewrite" : false },
    "wrapMultilineFunctionChains" : { "lint" : "no", "rewrite" : false },
    "wrapMultilineStatementBraces" : { "lint" : "no", "rewrite" : false },
    "wrapSingleLineBodies" : { "lint" : "no", "mode" : "wrap", "rewrite" : false }
  }
}
