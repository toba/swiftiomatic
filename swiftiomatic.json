{
	"$schema": "https://raw.githubusercontent.com/toba/swiftiomatic/refs/heads/main/swiftiomatic.schema.json",
	"acronyms": {
		"words": [
			"ID",
			"URL",
			"UUID",
			"HTTP",
			"HTTPS",
			"JSON",
			"XML",
			"HTML",
			"API",
			"TCP",
			"UDP",
			"DNS",
			"SSH",
			"FTP",
			"SQL",
			"CSS",
			"RGB",
			"RGBA",
			"PDF",
			"GIF",
			"PNG",
			"JPEG"
		]
	},
	"extensionAccessControl": {
		"placement": "onDeclarations"
	},
	"fileHeader": {},
	"fileScopedDeclarationPrivacy": {
		"accessLevel": "private"
	},
	"indentation": {
		"spaces": 2
	},
	"indentBlankLines": false,
	"indentConditionalCompilationBlocks": true,
	"indentSwitchCaseLabels": false,
	"lineBreakAroundMultilineExpressionChainComponents": false,
	"lineBreakBeforeControlFlowKeywords": false,
	"lineBreakBeforeEachArgument": false,
	"lineBreakBeforeEachGenericRequirement": false,
	"lineBreakBetweenDeclarationAttributes": false,
	"lineLength": 100,
	"maximumBlankLines": 1,
	"multiElementCollectionTrailingCommas": true,
	"noAssignmentInExpressions": {
		"allowedFunctions": ["XCTAssertNoThrow"]
	},
	"patternLet": {
		"placement": "eachBinding"
	},
	"prioritizeKeepingFunctionOutputTogether": false,
	"reflowMultilineStringLiterals": "never",
	"respectsExistingLineBreaks": true,
	"rules": {
		"AmbiguousTrailingClosureOverload": true,
		"ASCIIIdentifiers": true,
		"BlankLinesAfterGuardStatements": false,
		"BlankLinesAfterImports": true,
		"BlankLinesAfterSwitchCase": false,
		"BlankLinesAroundMark": false,
		"BlankLinesBetweenChainedFunctions": false,
		"BlankLinesBetweenImports": false,
		"BlankLinesBetweenScopes": false,
		"CapitalizeAcronyms": false,
		"CapitalizedTypeNames": true,
		"ConsistentSwitchCaseSpacing": false,
		"DocComments": true,
		"DocCommentsBeforeModifiers": true,
		"DocCommentSummary": false,
		"DocumentPublicDeclarations": false,
		"EmptyBraces": true,
		"EmptyCollectionLiteral": false,
		"EmptyExtensions": true,
		"EnumNamespaces": true,
		"ExplicitNilCheck": true,
		"FileHeader": false,
		"FileScopedDeclarationPrivacy": true,
		"FormatSpecialComments": true,
		"FullyIndirectEnum": true,
		"GroupNumericLiterals": true,
		"HoistAwait": true,
		"HoistTry": true,
		"InitCoderUnavailable": false,
		"LeadingDotOperators": true,
		"LinebreakAtEndOfFile": false,
		"LowerCamelCase": true,
		"ModifierOrder": true,
		"ModifiersOnSameLine": true,
		"NoAssignmentInExpressions": true,
		"NoBacktickedSelf": true,
		"NoBlockComments": true,
		"NoEmptyLinesOpeningClosingBraces": false,
		"NoExplicitOwnership": false,
		"NoExtensionAccessLevel": true,
		"NoFallthroughOnlyCases": true,
		"NoForceTry": false,
		"NoForceUnwrap": false,
		"NoGuardInTests": false,
		"NoImplicitlyUnwrappedOptionals": false,
		"NoLabelsInCasePatterns": true,
		"NoLeadingUnderscores": false,
		"NoParensAroundConditions": true,
		"NoPlaygroundLiterals": true,
		"NoRetroactiveConformances": true,
		"NoSemicolons": true,
		"NoTrailingClosureParens": true,
		"NoTypeRepetitionInStaticProperties": true,
		"NoVoidReturnOnFunctionSignature": true,
		"NoYodaConditions": true,
		"OmitExplicitReturns": false,
		"OneDeclarationPerLine": true,
		"OnlyOneTrailingClosureArgument": true,
		"OpaqueGenericParameters": false,
		"PatternLetPlacement": true,
		"PreferAngleBracketExtensions": true,
		"PreferAnyObject": true,
		"PreferAssertionFailure": true,
		"PreferCommaConditions": true,
		"PreferConditionalExpression": false,
		"PreferCountWhere": true,
		"PreferEarlyExits": false,
		"PreferEnvironmentEntry": false,
		"PreferExplicitFalse": false,
		"PreferFileID": false,
		"PreferFinalClasses": false,
		"PreferIsEmpty": false,
		"PreferKeyPath": false,
		"PreferMainAttribute": true,
		"PreferShorthandTypeNames": true,
		"PreferSingleLinePropertyGetter": true,
		"PreferSwiftTesting": false,
		"PreferSynthesizedInitializer": true,
		"PreferTrailingClosures": true,
		"PreferVoidReturn": true,
		"PreferWhereClausesInForLoops": false,
		"PrivateStateVariables": false,
		"RedundantAccessControl": false,
		"RedundantAsync": false,
		"RedundantBackticks": true,
		"RedundantBreak": true,
		"RedundantClosure": true,
		"RedundantEquatable": false,
		"RedundantInit": true,
		"RedundantLet": true,
		"RedundantLetError": true,
		"RedundantNilInit": true,
		"RedundantObjc": true,
		"RedundantOptionalBinding": true,
		"RedundantPattern": true,
		"RedundantProperty": true,
		"RedundantRawValues": true,
		"RedundantSelf": true,
		"RedundantSendable": false,
		"RedundantStaticSelf": false,
		"RedundantSwiftTestingSuite": false,
		"RedundantThrows": false,
		"RedundantType": true,
		"RedundantTypedThrows": true,
		"RedundantViewBuilder": false,
		"ReplaceForEachWithForLoop": true,
		"SimplifyGenericConstraints": true,
		"SortDeclarations": true,
		"SortImports": true,
		"SortSwitchCases": false,
		"SortTypealiases": true,
		"StrongOutlets": true,
		"SwiftTestingTestCaseNames": false,
		"TestSuiteAccessControl": false,
		"TripleSlashDocComments": true,
		"UnusedArguments": true,
		"URLMacro": false,
		"ValidateDocumentationComments": false,
		"ValidateTestCases": false,
		"WrapBodies": false,
		"WrapConditionalAssignment": false,
		"WrapMultilineFunctionChains": false,
		"WrapMultilineStatementBraces": false,
		"WrapSingleLineComments": false,
		"WrapSwitchCases": false
	},
	"sortImports": {
		"includeConditionalImports": false,
		"shouldGroupImports": true
	},
	"spacesAroundRangeFormationOperators": false,
	"spacesBeforeEndOfLineComments": 2,
	"tabWidth": 8,
	"urlMacro": {},
	"version": 1
}
