{
  "$schema" : "https://raw.githubusercontent.com/toba/swiftiomatic/refs/heads/main/schema.json",
  "AmbiguousTrailingClosureOverload" : "warn",
  "ASCIIIdentifiers" : "warn",
  "capitalization" : {
    "capitalizeAcronyms" : "off",
    "capitalizedTypeNames" : "warn",
    "lowerCamelCase" : "warn"
  },
  "ConsistentSwitchCaseSpacing" : "off",
  "DocComments" : "fix",
  "DocCommentsBeforeModifiers" : "fix",
  "DocCommentSummary" : "off",
  "DocumentPublicDeclarations" : "off",
  "EmptyBraces" : "fix",
  "EmptyCollectionLiteral" : "off",
  "EmptyExtensions" : "fix",
  "EnumNamespaces" : "fix",
  "ExplicitNilCheck" : "fix",
  "FileHeader" : {
    "mode" : "off"
  },
  "FileScopedDeclarationPrivacy" : {
    "accessLevel" : "private",
    "mode" : "fix"
  },
  "FormatSpecialComments" : "fix",
  "FullyIndirectEnum" : "fix",
  "GroupNumericLiterals" : "fix",
  "HoistAwait" : "fix",
  "HoistTry" : "fix",
  "indentation" : {
    "spaces" : 2
  },
  "indentBlankLines" : false,
  "indentConditionalCompilationBlocks" : true,
  "indentSwitchCaseLabels" : false,
  "InitCoderUnavailable" : "off",
  "LeadingDotOperators" : "fix",
  "lineLength" : 100,
  "ModifierOrder" : "fix",
  "ModifiersOnSameLine" : "fix",
  "multiElementCollectionTrailingCommas" : true,
  "multilineTrailingCommaBehavior" : "keptAsWritten",
  "NoAssignmentInExpressions" : {
    "allowedFunctions" : [
      "XCTAssertNoThrow"
    ],
    "mode" : "fix"
  },
  "NoBacktickedSelf" : "fix",
  "NoBlockComments" : "warn",
  "NoEmptyLinesOpeningClosingBraces" : "off",
  "NoExplicitOwnership" : "off",
  "NoExtensionAccessLevel" : {
    "mode" : "fix",
    "placement" : "onDeclarations"
  },
  "NoFallthroughOnlyCases" : "fix",
  "NoForceTry" : "off",
  "NoForceUnwrap" : "off",
  "NoGuardInTests" : "off",
  "NoImplicitlyUnwrappedOptionals" : "off",
  "NoLabelsInCasePatterns" : "fix",
  "NoLeadingUnderscores" : "off",
  "NoParensAroundConditions" : "fix",
  "NoPlaygroundLiterals" : "warn",
  "NoRetroactiveConformances" : "warn",
  "NoSemicolons" : "fix",
  "NoTrailingClosureParens" : "fix",
  "NoTypeRepetitionInStaticProperties" : "warn",
  "NoVoidReturnOnFunctionSignature" : "fix",
  "NoYodaConditions" : "fix",
  "OneDeclarationPerLine" : "fix",
  "OnlyOneTrailingClosureArgument" : "warn",
  "OpaqueGenericParameters" : "off",
  "PatternLetPlacement" : {
    "mode" : "fix",
    "placement" : "eachBinding"
  },
  "PreferAngleBracketExtensions" : "fix",
  "PreferAnyObject" : "fix",
  "PreferAssertionFailure" : "fix",
  "PreferCommaConditions" : "fix",
  "PreferConditionalExpression" : "off",
  "PreferCountWhere" : "fix",
  "PreferEarlyExits" : "off",
  "PreferEnvironmentEntry" : "off",
  "PreferExplicitFalse" : "off",
  "PreferFileID" : "off",
  "PreferFinalClasses" : "off",
  "PreferIsEmpty" : "off",
  "PreferKeyPath" : "off",
  "PreferMainAttribute" : "fix",
  "PreferShorthandTypeNames" : "fix",
  "PreferSingleLinePropertyGetter" : "fix",
  "PreferSwiftTesting" : "off",
  "PreferSynthesizedInitializer" : "warn",
  "PreferTrailingClosures" : "fix",
  "PreferVoidReturn" : "fix",
  "PreferWhereClausesInForLoops" : "off",
  "prioritizeKeepingFunctionOutputTogether" : false,
  "PrivateStateVariables" : "off",
  "reflowMultilineStringLiterals" : "never",
  "removeRedundant" : {
    "accessControl" : "off",
    "async" : "off",
    "backticks" : "fix",
    "break" : "fix",
    "closure" : "fix",
    "equatable" : "off",
    "init" : "fix",
    "let" : "fix",
    "letError" : "fix",
    "nilInit" : "fix",
    "objc" : "fix",
    "optionalBinding" : "fix",
    "pattern" : "fix",
    "property" : "fix",
    "rawValues" : "fix",
    "return" : "off",
    "self" : "fix",
    "sendable" : "off",
    "staticSelf" : "off",
    "swiftTestingSuite" : "off",
    "throws" : "off",
    "type" : "fix",
    "typedThrows" : "fix",
    "viewBuilder" : "off"
  },
  "ReplaceForEachWithForLoop" : "warn",
  "respectsExistingLineBreaks" : true,
  "SimplifyGenericConstraints" : "fix",
  "sort" : {
    "declarations" : "fix",
    "imports" : "fix",
    "switchCases" : "off",
    "typealiases" : "fix"
  },
  "spacesAroundRangeFormationOperators" : false,
  "spacesBeforeEndOfLineComments" : 2,
  "StrongOutlets" : "fix",
  "SwiftTestingTestCaseNames" : "off",
  "tabWidth" : 8,
  "TestSuiteAccessControl" : "off",
  "TripleSlashDocComments" : "fix",
  "UnusedArguments" : "fix",
  "updateBlankLines" : {
    "afterGuardStatements" : "off",
    "afterImports" : "fix",
    "afterSwitchCase" : "off",
    "aroundMark" : "off",
    "betweenChainedFunctions" : "off",
    "betweenImports" : "off",
    "betweenScopes" : "off",
    "maximumBlankLines" : 1
  },
  "updateLineBreak" : {
    "aroundMultilineExpressionChainComponents" : false,
    "atEndOfFile" : "off",
    "beforeControlFlowKeywords" : false,
    "beforeEachArgument" : false,
    "beforeEachGenericRequirement" : false,
    "betweenDeclarationAttributes" : false
  },
  "URLMacro" : {
    "mode" : "off"
  },
  "ValidateDocumentationComments" : "off",
  "ValidateTestCases" : "off",
  "version" : 4,
  "wrap" : {
    "bodies" : "off",
    "conditionalAssignment" : "off",
    "multilineFunctionChains" : "off",
    "multilineStatementBraces" : "off",
    "singleLineComments" : "off",
    "switchCases" : "off"
  }
}
