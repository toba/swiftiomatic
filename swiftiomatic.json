{
	"$schema": "https://raw.githubusercontent.com/toba/swiftiomatic/refs/heads/main/schema.json",
	"version": 3,
	"format": {
		"indentation": {
			"spaces": 2
		},
		"indentBlankLines": false,
		"indentConditionalCompilationBlocks": true,
		"indentSwitchCaseLabels": false,
		"lineBreakAroundMultilineExpressionChainComponents": false,
		"lineBreakBeforeControlFlowKeywords": false,
		"lineBreakBeforeEachArgument": false,
		"lineBreakBeforeEachGenericRequirement": false,
		"lineBreakBetweenDeclarationAttributes": false,
		"lineLength": 100,
		"multiElementCollectionTrailingCommas": true,
		"prioritizeKeepingFunctionOutputTogether": false,
		"reflowMultilineStringLiterals": "never",
		"respectsExistingLineBreaks": true,
		"spacesAroundRangeFormationOperators": false,
		"spacesBeforeEndOfLineComments": 2,
		"tabWidth": 8,
		"UpdateBlankLines": {
			"severity": "warn",
			"maximumBlankLines": 1,
			"afterGuardStatements": false,
			"afterImports": true,
			"afterSwitchCase": false,
			"aroundMark": false,
			"betweenChainedFunctions": false,
			"betweenImports": false,
			"betweenScopes": false
		},
		"CapitalizeAcronyms": {
			"severity": "off",
			"words": [
				"ID",
				"URL",
				"UUID",
				"HTTP",
				"HTTPS",
				"JSON",
				"XML",
				"HTML",
				"API",
				"TCP",
				"UDP",
				"DNS",
				"SSH",
				"FTP",
				"SQL",
				"CSS",
				"RGB",
				"RGBA",
				"PDF",
				"GIF",
				"PNG",
				"JPEG"
			]
		},
		"ConsistentSwitchCaseSpacing": "off",
		"DocComments": "warn",
		"DocCommentsBeforeModifiers": "warn",
		"EmptyBraces": "warn",
		"EmptyCollectionLiteral": "off",
		"EmptyExtensions": "warn",
		"EnumNamespaces": "warn",
		"ExplicitNilCheck": "warn",
		"FileHeader": {
			"severity": "off"
		},
		"FileScopedDeclarationPrivacy": {
			"accessLevel": "private",
			"severity": "warn"
		},
		"FormatSpecialComments": "warn",
		"FullyIndirectEnum": "warn",
		"GroupNumericLiterals": "warn",
		"HoistAwait": "warn",
		"HoistTry": "warn",
		"InitCoderUnavailable": "off",
		"LeadingDotOperators": "warn",
		"LinebreakAtEndOfFile": "off",
		"ModifierOrder": "warn",
		"ModifiersOnSameLine": "warn",
		"NoAssignmentInExpressions": {
			"allowedFunctions": ["XCTAssertNoThrow"],
			"severity": "warn"
		},
		"NoBacktickedSelf": "warn",
		"NoEmptyLinesOpeningClosingBraces": "off",
		"NoExplicitOwnership": "off",
		"NoExtensionAccessLevel": {
			"severity": "warn",
			"placement": "onDeclarations"
		},
		"NoFallthroughOnlyCases": "warn",
		"NoForceTry": "off",
		"NoForceUnwrap": "off",
		"NoGuardInTests": "off",
		"NoLabelsInCasePatterns": "warn",
		"NoParensAroundConditions": "warn",
		"NoSemicolons": "warn",
		"NoTrailingClosureParens": "warn",
		"NoVoidReturnOnFunctionSignature": "warn",
		"NoYodaConditions": "warn",
		"OmitExplicitReturns": "off",
		"OneDeclarationPerLine": "warn",
		"OpaqueGenericParameters": "off",
		"PatternLetPlacement": {
			"severity": "warn",
			"placement": "eachBinding"
		},
		"PreferAngleBracketExtensions": "warn",
		"PreferAnyObject": "warn",
		"PreferAssertionFailure": "warn",
		"PreferCommaConditions": "warn",
		"PreferConditionalExpression": "off",
		"PreferCountWhere": "warn",
		"PreferEarlyExits": "off",
		"PreferEnvironmentEntry": "off",
		"PreferExplicitFalse": "off",
		"PreferFileID": "off",
		"PreferFinalClasses": "off",
		"PreferIsEmpty": "off",
		"PreferKeyPath": "off",
		"PreferMainAttribute": "warn",
		"PreferShorthandTypeNames": "warn",
		"PreferSingleLinePropertyGetter": "warn",
		"PreferSwiftTesting": "off",
		"PreferTrailingClosures": "warn",
		"PreferVoidReturn": "warn",
		"PreferWhereClausesInForLoops": "off",
		"PrivateStateVariables": "off",
		"RemoveRedundant": {
			"severity": "warn",
			"accessControl": false,
			"async": false,
			"backticks": true,
			"break": true,
			"closure": true,
			"equatable": false,
			"init": true,
			"let": true,
			"letError": true,
			"nilInit": true,
			"objc": true,
			"optionalBinding": true,
			"pattern": true,
			"property": true,
			"rawValues": true,
			"self": true,
			"sendable": false,
			"staticSelf": false,
			"swiftTestingSuite": false,
			"throws": false,
			"type": true,
			"typedThrows": true,
			"viewBuilder": false
		},
		"SimplifyGenericConstraints": "warn",
		"SortDeclarations": "warn",
		"SortImports": {
			"severity": "warn",
			"includeConditionalImports": false,
			"shouldGroupImports": true
		},
		"SortSwitchCases": "off",
		"SortTypealiases": "warn",
		"StrongOutlets": "warn",
		"SwiftTestingTestCaseNames": "off",
		"TestSuiteAccessControl": "off",
		"TripleSlashDocComments": "warn",
		"URLMacro": {
			"severity": "off"
		},
		"UnusedArguments": "warn",
		"ValidateTestCases": "off",
		"WrapBodies": "off",
		"WrapConditionalAssignment": "off",
		"WrapMultilineFunctionChains": "off",
		"WrapMultilineStatementBraces": "off",
		"WrapSingleLineComments": "off",
		"WrapSwitchCases": "off"
	},
	"lint": {
		"AmbiguousTrailingClosureOverload": "warn",
		"ASCIIIdentifiers": "warn",
		"CapitalizedTypeNames": "warn",
		"DocCommentSummary": "off",
		"DocumentPublicDeclarations": "off",
		"LowerCamelCase": "warn",
		"NoBlockComments": "warn",
		"NoImplicitlyUnwrappedOptionals": "off",
		"NoLeadingUnderscores": "off",
		"NoPlaygroundLiterals": "warn",
		"NoRetroactiveConformances": "warn",
		"NoTypeRepetitionInStaticProperties": "warn",
		"OnlyOneTrailingClosureArgument": "warn",
		"PreferSynthesizedInitializer": "warn",
		"ReplaceForEachWithForLoop": "warn",
		"ValidateDocumentationComments": "off"
	}
}
