{
	"$schema": "https://raw.githubusercontent.com/toba/swiftiomatic/refs/heads/main/schema.json",
	"AmbiguousTrailingClosureOverload": "warn",
	"blankLines": {
		"blankLinesAfterGuardStatements": "off",
		"blankLinesAfterImports": "autoFix",
		"blankLinesAfterSwitchCase": "off",
		"blankLinesAroundMark": "off",
		"blankLinesBetweenChainedFunctions": "off",
		"blankLinesBetweenImports": "off",
		"blankLinesBetweenScopes": "off",
		"consistentSwitchCaseSpacing": "off",
		"maximumBlankLines": 1
	},
	"capitalization": {
		"capitalizeAcronyms": {
			"mode": "off",
			"words": [
				"ID",
				"URL",
				"UUID",
				"HTTP",
				"HTTPS",
				"JSON",
				"XML",
				"HTML",
				"API",
				"TCP",
				"UDP",
				"DNS",
				"SSH",
				"FTP",
				"SQL",
				"CSS",
				"RGB",
				"RGBA",
				"PDF",
				"GIF",
				"PNG",
				"JPEG"
			]
		},
		"capitalizedTypeNames": "warn",
		"lowerCamelCase": "warn"
	},
	"comments": {
		"convertRegularCommentToDocC": "off",
		"docCommentsBeforeModifiers": "autoFix",
		"docCommentSummary": "off",
		"formatSpecialComments": "autoFix",
		"noBlockComments": "warn",
		"tripleSlashDocComments": "autoFix",
		"validateDocumentationComments": "off"
	},
	"DocumentPublicDeclarations": "off",
	"EmptyBraces": "autoFix",
	"EmptyCollectionLiteral": "off",
	"EmptyExtensions": "autoFix",
	"EnumNamespaces": "autoFix",
	"ExplicitNilCheck": "autoFix",
	"FileHeader": {
		"mode": "off"
	},
	"FileScopedDeclarationPrivacy": {
		"accessLevel": "private",
		"mode": "autoFix"
	},
	"FullyIndirectEnum": "autoFix",
	"GroupNumericLiterals": "autoFix",
	"hoist": {
		"moveInlineAwaitToExpressionStart": "autoFix",
		"moveInlineTryToExpressionStart": "autoFix"
	},
	"identifiersMayOnlyUseASCII": "warn",
	"indentation": {
		"blankLines": false,
		"conditionalCompilationBlocks": true,
		"switchCaseIndentation": {
			"mode": "autoFix",
			"style": "indented"
		}
	},
	"InitCoderUnavailable": "off",
	"LeadingDotOperators": "autoFix",
	"lineBreaks": {
		"aroundMultilineExpressionChainComponents": false,
		"beforeControlFlowKeywords": false,
		"beforeEachArgument": false,
		"beforeEachGenericRequirement": false,
		"beforeGuardConditions": true,
		"betweenDeclarationAttributes": false,
		"ensureLineBreakAtEOF": "off",
		"modifiersOnSameLine": "autoFix"
	},
	"lineLength": 100,
	"ModifierOrder": "autoFix",
	"multiElementCollectionTrailingCommas": true,
	"multilineTrailingCommaBehavior": "keptAsWritten",
	"NoAssignmentInExpressions": {
		"allowedFunctions": ["XCTAssertNoThrow"],
		"mode": "autoFix"
	},
	"NoBacktickedSelf": "autoFix",
	"NoEmptyLinesOpeningClosingBraces": "off",
	"NoExplicitOwnership": "off",
	"NoExtensionAccessLevel": {
		"mode": "autoFix",
		"placement": "onDeclarations"
	},
	"NoFallthroughOnlyCases": "autoFix",
	"NoForceTry": "off",
	"NoForceUnwrap": "off",
	"NoGuardInTests": "off",
	"NoImplicitlyUnwrappedOptionals": "off",
	"NoLabelsInCasePatterns": "autoFix",
	"NoLeadingUnderscores": "off",
	"NoParensAroundConditions": "autoFix",
	"NoPlaygroundLiterals": "warn",
	"NoRetroactiveConformances": "warn",
	"NoSemicolons": "autoFix",
	"NoTrailingClosureParens": "autoFix",
	"NoTypeRepetitionInStaticProperties": "warn",
	"NoVoidReturnOnFunctionSignature": "autoFix",
	"NoYodaConditions": "autoFix",
	"OneDeclarationPerLine": "autoFix",
	"OnlyOneTrailingClosureArgument": "warn",
	"OpaqueGenericParameters": "off",
	"PatternLetPlacement": {
		"mode": "autoFix",
		"placement": "eachBinding"
	},
	"PreferAngleBracketExtensions": "autoFix",
	"PreferAnyObject": "autoFix",
	"PreferAssertionFailure": "autoFix",
	"PreferCommaConditions": "autoFix",
	"PreferConditionalExpression": "off",
	"PreferCountWhere": "autoFix",
	"PreferEarlyExits": "off",
	"PreferEnvironmentEntry": "off",
	"PreferExplicitFalse": "off",
	"PreferFileID": "off",
	"PreferFinalClasses": "off",
	"PreferIsEmpty": "off",
	"PreferKeyPath": "off",
	"PreferMainAttribute": "autoFix",
	"PreferShorthandTypeNames": "autoFix",
	"PreferSingleLinePropertyGetter": "autoFix",
	"PreferSwiftTesting": "off",
	"PreferSynthesizedInitializer": "warn",
	"PreferTrailingClosures": "autoFix",
	"PreferVoidReturn": "autoFix",
	"PreferWhereClausesInForLoops": "off",
	"prioritizeKeepingFunctionOutputTogether": false,
	"PrivateStateVariables": "off",
	"redundancies": {
		"redundantAccessControl": "off",
		"redundantAsync": "off",
		"redundantBackticks": "autoFix",
		"redundantBreak": "autoFix",
		"redundantClosure": "autoFix",
		"redundantEquatable": "off",
		"redundantInit": "autoFix",
		"redundantLet": "autoFix",
		"redundantLetError": "autoFix",
		"redundantNilInit": "autoFix",
		"redundantObjc": "autoFix",
		"redundantOptionalBinding": "autoFix",
		"redundantPattern": "autoFix",
		"redundantProperty": "autoFix",
		"redundantRawValues": "autoFix",
		"redundantReturn": "off",
		"redundantSelf": "autoFix",
		"redundantSendable": "off",
		"redundantStaticSelf": "off",
		"redundantSwiftTestingSuite": "off",
		"redundantThrows": "off",
		"redundantType": "autoFix",
		"redundantTypedThrows": "autoFix",
		"redundantViewBuilder": "off"
	},
	"reflowMultilineStringLiterals": "never",
	"ReplaceForEachWithForLoop": "warn",
	"respectsExistingLineBreaks": true,
	"SimplifyGenericConstraints": "autoFix",
	"sort": {
		"sortDeclarations": "autoFix",
		"sortImports": {
			"includeConditionalImports": false,
			"mode": "autoFix",
			"shouldGroupImports": true
		},
		"sortSwitchCases": "off",
		"sortTypealiases": "autoFix"
	},
	"spacesAroundRangeFormationOperators": false,
	"spacesBeforeEndOfLineComments": 2,
	"StrongOutlets": "autoFix",
	"SwiftTestingTestCaseNames": "off",
	"tabWidth": 8,
	"TestSuiteAccessControl": "off",
	"UnusedArguments": "autoFix",
	"URLMacro": {
		"mode": "off"
	},
	"ValidateTestCases": "off",
	"version": 4,
	"wrap": {
		"singleLineComments": "off",
		"wrapCompoundCaseStatements": "off",
		"wrapConditionalAssignment": "off",
		"wrapMultilineFunctionChains": "off",
		"wrapMultilineStatementBraces": "off",
		"wrapSingleLineBodies": {
			"mode": "autoFix"
		}
	}
}
